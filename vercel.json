{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "server.js"
    },
    {
      "src": "/(.*)",
      "status": 404,
      "statusText": "Rota principal nao encontrada. Use os endpoints da API (/api/...)"
    }
  ]
}